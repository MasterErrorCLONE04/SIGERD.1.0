  {
    "id": "TC013",
    "title": "Instructor cannot submit an incident without an image",
    "description": "Verifies image attachment is required and the UI blocks creation when no image is provided.",
    "category": "Incident Management (Instructor & Admin)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"Incidents\" navigation item to go to the Instructor Incidents page"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/instructor/incidents\""
      },
      {
        "type": "action",
        "description": "Click the \"Report Incident\" button"
      },
      {
        "type": "action",
        "description": "Type \"Broken window\" into the Title field"
      },
      {
        "type": "action",
        "description": "Type \"Room 203\" into the Location field"
      },
      {
        "type": "action",
        "description": "Click the \"Submit\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Must provide at least one image\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Broken window\" is not visible"
      }
    ]
  },
