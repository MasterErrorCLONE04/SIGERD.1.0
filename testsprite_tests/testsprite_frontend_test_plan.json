  {
    "id": "TC009",
    "title": "Admin creates a new user and sees it in the users list",
    "description": "Verifies an admin can create a new user from the Admin Users page and the new user appears in the list.",
    "category": "User Management (Admin)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Users\" item in the admin navigation menu"
      },
      {
        "type": "action",
        "description": "Click the \"Create New User\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Create User\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"e2e.admin.create.user@example.com\" into the Email field"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"e2e.admin.create.user@example.com\" is visible"
      }
    ]
  },
