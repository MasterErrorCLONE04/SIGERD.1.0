[
  {
    "id": "TC001",
    "title": "Admin is redirected from /dashboard to /admin/dashboard and sees overview metrics",
    "description": "Verifies an Admin user lands on the Admin dashboard after login and can see overview metrics.",
    "category": "Role-Based Dashboards",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "action",
        "description": "Navigate to /dashboard"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Overview\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"overview metrics\" is visible"
      }
    ]
  },
